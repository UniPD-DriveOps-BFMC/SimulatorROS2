<launch>
  <node pkg="depth_image_proc" exec="point_cloud_xyzrgb_node"
        name="oak_pointcloud">
    <remap from="depth_registered/image_rect" to="/oak/stereo/image_fixed"/>
    <remap from="rgb/image_rect_color"        to="/oak/rgb/image_raw"/>
    <remap from="rgb/camera_info"             to="/oak/rgb/camera_info"/>
    <remap from="points"                      to="/oak/points"/>
    <param name="queue_size" value="10"/>
    <param name="exact_sync" value="false"/>
  </node>
</launch>
